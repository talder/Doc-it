        <mxCell id="merge" value="&lt;b&gt;Parse XML &amp; Merge&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;fast-xml-parser → merge channels + statuses by ID&lt;br&gt;includes orphan statuses not in channel list&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
