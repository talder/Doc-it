        <mxCell id="ctx1" value="getPrevSnapshots()&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;last poll's channel states&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#d6b656;" vertex="1" parent="grp_ctx">
