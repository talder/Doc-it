          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ NOTIFICATION FLOW ═══════════════ -->
        <mxCell id="grp_notif" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#f87171;dashed=1;dashPattern=5 5;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="520" y="1250" width="440" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="notif_title" value="🔔 Notification Logic — per channel" style="text;html=1;align=left;fontStyle=1;fontSize=12;fillColor=none;strokeColor=none;" vertex="1" parent="grp_notif">
          <mxGeometry x="10" y="5" width="300" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="d_should" value="shouldNotify()&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;prev → new health?&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="155" y="35" width="130" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="d_calm" value="prev in&lt;br&gt;CALM set?&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;{healthy, paused,&lt;br&gt;disabled}&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="155" y="115" width="130" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_should_calm" value="has baseline" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;fontSize=9;" edge="1" source="d_should" target="d_calm" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="skip_nobase" value="&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;Skip — no baseline&lt;br&gt;(prev unknown/missing)&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="grp_notif">
          <mxGeometry x="310" y="45" width="120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="e_should_skip" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#aaa;dashed=1;" edge="1" source="d_should" target="skip_nobase" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="skip_already" value="&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;Skip — was&lt;br&gt;already alerting&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="grp_notif">
          <mxGeometry x="10" y="128" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="e_calm_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#aaa;dashed=1;fontSize=9;" edge="1" source="d_calm" target="skip_already" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d_alert" value="new in&lt;br&gt;ALERT set?&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;{error, down,&lt;br&gt;stuck}&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="310" y="115" width="115" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_calm_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;fontSize=9;fontStyle=1;" edge="1" source="d_calm" target="d_alert" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="skip_ok" value="&lt;font color=&quot;#888&quot; style=&quot;font-size:9px&quot;&gt;Skip — still calm&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="grp_notif">
          <mxGeometry x="320" y="192" width="100" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="e_alert_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#aaa;dashed=1;fontSize=9;" edge="1" source="d_alert" target="skip_ok" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="transition" value="✅ Calm → Alert transition detected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=10;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="75" y="215" width="210" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="e_alert_yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#22c55e;fontSize=9;fontStyle=1;" edge="1" source="d_alert" target="transition" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d_toggle" value="per-server&lt;br&gt;toggle on?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="10" y="255" width="100" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e_trans_toggle" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="transition" target="d_toggle" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="send_email" value="📧 notifyAdminsOfMirthAlert()&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;email to custom recipients or admins&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3b82f6;fontColor=#fff;strokeColor=#2563eb;fontSize=10;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="10" y="320" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_toggle_send" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3b82f6;fontSize=9;fontStyle=1;" edge="1" source="d_toggle" target="send_email" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="always_audit" value="📋 Audit log &amp; 📜 History log&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ALWAYS written regardless of toggle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="grp_notif">
          <mxGeometry x="200" y="260" width="220" height="38" as="geometry"/>
        </mxCell>
        <mxCell id="e_trans_audit" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;" edge="1" source="transition" target="always_audit" parent="grp_notif">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e_class_notif" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="grp_class" target="grp_notif" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ RESPONSE ═══════════════ -->
        <mxCell id="grp_resp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;dashed=1;dashPattern=5 5;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="200" y="1620" width="600" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="resp_title" value="📦 Dashboard Response — aggregated across all servers" style="text;html=1;align=left;fontStyle=1;fontSize=12;fillColor=none;strokeColor=none;" vertex="1" parent="grp_resp">
          <mxGeometry x="10" y="5" width="400" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="resp1" value="&lt;b&gt;worstHealth()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;per server&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#22c55e;" vertex="1" parent="grp_resp">
          <mxGeometry x="15" y="35" width="130" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="resp2" value="&lt;b&gt;summaryCounts&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;per health type&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#22c55e;" vertex="1" parent="grp_resp">
          <mxGeometry x="155" y="35" width="130" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="resp3" value="&lt;b&gt;issueChannels&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;sorted: down &gt; error &gt; stuck &gt; …&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#22c55e;" vertex="1" parent="grp_resp">
          <mxGeometry x="295" y="35" width="160" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="resp4" value="&lt;b&gt;lastPolledAt&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;new Date().toISOString()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#22c55e;" vertex="1" parent="grp_resp">
          <mxGeometry x="465" y="35" width="125" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="resp_json" value="→ JSON response to caller (frontend or background poller)" style="text;html=1;align=center;fontSize=10;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="grp_resp">
          <mxGeometry x="80" y="80" width="440" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="e_persist_resp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="grp_persist" target="grp_resp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_notif_resp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="grp_notif" target="grp_resp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
