        <mxCell id="e_err_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;fontSize=10;fontStyle=1;" edge="1" source="d_errors" target="h_error" parent="grp_class">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="d_inactive" value="inactive?&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;checkInactivity()&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="grp_class">
