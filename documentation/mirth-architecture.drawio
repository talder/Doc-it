        <mxCell id="ctx7" value="getNotificationConfig()&lt;br&gt;&lt;font style=&quot;font-size:9px;color:#666&quot;&gt;per-server alert toggles + recipients&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#d6b656;" vertex="1" parent="grp_ctx">
          <mxGeometry x="45" y="168" width="190" height="38" as="geometry"/>
