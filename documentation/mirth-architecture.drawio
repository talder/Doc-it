<mxfile host="app.diagrams.net" agent="doc-it" version="26.0">
  <diagram name="Mirth Module Flow" id="mirth-flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════ TRIGGERS ═══════════════ -->
        <mxCell id="grp_triggers" value="Triggers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=5;dashed=1;dashPattern=5 5;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="140" y="30" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="trigger_poll" value="⏱ &lt;b&gt;Background Poller&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;instrumentation-node.ts&lt;br&gt;every 10 min + 30s after boot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="grp_triggers">
          <mxGeometry x="30" y="30" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="trigger_ui" value="🖥 &lt;b&gt;Frontend / API Call&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;GET /api/mirth/dashboard&lt;br&gt;manual refresh or auto-refresh&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="grp_triggers">
          <mxGeometry x="470" y="30" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ MAIN FUNCTION ═══════════════ -->
        <mxCell id="gmd" value="&lt;b&gt;getMirthDashboard()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;lib/mirth.ts — orchestrates full poll cycle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4f46e5;fontColor=#ffffff;strokeColor=#3730a3;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="180" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e_poll_gmd" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="trigger_poll" target="gmd" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ui_gmd" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="trigger_ui" target="gmd" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="list_servers" value="listMirthServers()&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;SQLite: mirth_servers → filter enabled&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="270" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_gmd_list" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="gmd" target="list_servers" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="par_loop" value="&lt;b&gt;For each enabled server&lt;/b&gt; (Promise.all — parallel)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="340" width="260" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_list_par" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;" edge="1" source="list_servers" target="par_loop" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ═══════════════ CONTEXT LOADING ═══════════════ -->
        <mxCell id="grp_ctx" value="Load Context from SQLite" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;verticalAlign=top;spacingTop=5;container=1;collapsible=0;" vertex="1" parent="1">
