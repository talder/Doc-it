        <mxCell id="err_note" value="&lt;font style=&quot;font-size:9px;color:#888&quot;&gt;unacked = ch.error − ackedErrors&lt;br&gt;increasing = !prev OR ch.error &gt; prev.error&lt;/font&gt;" style="text;html=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="grp_class">
