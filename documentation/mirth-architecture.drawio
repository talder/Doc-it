        <mxCell id="e_inact_yes" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;fontSize=10;fontStyle=1;" edge="1" source="d_inactive" target="h_stuck_i" parent="grp_class">
