        <mxCell id="e_err_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666;fontSize=10;fontStyle=1;" edge="1" source="d_errors" target="d_inactive" parent="grp_class">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="inact_note" value="&lt;font style=&quot;font-size:9px;color:#888&quot;&gt;Compares current received count vs&lt;br&gt;snapshot from N minutes ago (default 60).&lt;br&gt;If same → no new messages → inactive.&lt;br&gt;Configurable &amp; disablable per channel.&lt;/font&gt;" style="text;html=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="grp_class">
          <mxGeometry x="530" y="315" width="230" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="h_stuck_i" value="🟠 STUCK&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(inactivity)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f97316;fontColor=#fff;strokeColor=#ea580c;fontSize=11;fontStyle=1;" vertex="1" parent="grp_class">
