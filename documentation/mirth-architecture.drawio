        <!-- STARTED branch -->
        <mxCell id="d_errors" value="unacked errors &gt; 0&lt;br&gt;AND errors&lt;br&gt;increasing?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="grp_class">
