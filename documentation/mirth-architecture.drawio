        <mxCell id="h_unknown" value="❓ UNKNOWN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1d5db;strokeColor=#9ca3af;fontSize=11;fontStyle=1;" vertex="1" parent="grp_class">
