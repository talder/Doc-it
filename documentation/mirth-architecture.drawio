        <mxCell id="h_stuck_q" value="🟠 STUCK&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;(queued msgs)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f97316;fontColor=#fff;strokeColor=#ea580c;fontSize=11;fontStyle=1;" vertex="1" parent="grp_class">
