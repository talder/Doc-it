        <!-- ═══════════════ API FETCH ═══════════════ -->
        <mxCell id="grp_fetch" value="Fetch from Mirth Connect API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;verticalAlign=top;spacingTop=5;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="660" y="410" width="280" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="fetch_note" value="&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;mirthFetch() — Basic auth, 10s timeout&lt;br&gt;SSL errors optionally ignored per server&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="grp_fetch">
          <mxGeometry x="10" y="28" width="260" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="fetch_v" value="GET /api/server/version" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff;strokeColor=#82b366;" vertex="1" parent="grp_fetch">
          <mxGeometry x="15" y="62" width="160" height="28" as="geometry"/>
